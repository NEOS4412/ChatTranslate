# ── 大文件 / 临时文件 ──
*.pdf
*.jpg
*.jpeg
*.png
*.jsonl
*.key

# ── API 密钥 ──
.env

# ── 流水线中间数据（可重新生成） ──
books/*/stages/
!books/*/stages/*/keep
books/*/ocr/
books/*/translated/
books/*/proofread/suggestions.json
books/*/untranslated_report.json

# ── 逐页翻译产物（v1，已废弃） ──
books/*/translated/page_*.md
books/*/translated/chapters/

# ── Python ──
__pycache__/
*.pyc
*.pyo

# ── macOS ──
.DS_Store

# ── EPUB 输出（太大，可重建） ──
output/*.epub
!output/.gitkeep

# ── 构建临时文件 ──
tmp/
/tmp/
