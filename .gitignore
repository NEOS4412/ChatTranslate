# 大文件 / 临时文件
*.pdf
*.jpg
*.jpeg
*.png
*.jsonl

# API tokens 和密钥（不在文件里写，用环境变量）
.env
*.key

# OCR 原始输出（可重新生成）
books/*/ocr/doc_*.md
books/*/ocr/images/
books/*/ocr/_result.jsonl
books/*/ocr/full_raw.md

# Python 缓存
__pycache__/
*.pyc

# macOS
.DS_Store

# 逐页翻译结果（v1 产物，可重新生成）
books/*/translated/page_*.md

# 章节翻译结果代码不跟踪具体内容（仅跟踪目录结构示例）
books/*/translated/chapters/

# checkpoints 等
books/*/untranslated_report.json

# EPUB 输出（太大，可重新构建）
output/*.epub
